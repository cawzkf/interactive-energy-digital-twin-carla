  <submodels>
    <submodel>
      <idShort>TimeSeries</idShort>
      <id>https://marchforce.org/sm/timeseries</id>
      <kind>Instance</kind>
      <semanticId>
        <type>ExternalReference</type>
        <keys>
          <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/1/1</value></key>
        </keys>
      </semanticId>
      <submodelElements>

        <submodelElementCollection>
          <idShort>Metadata</idShort>
          <semanticId>
            <type>ExternalReference</type>
            <keys>
              <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/Metadata/1/1</value></key>
            </keys>
          </semanticId>
          <value>
            <property>
              <idShort>Name</idShort>
              <valueType>xs:string</valueType>
              <value>MarchForce Energy Telemetry</value>
            </property>
            <property>
              <idShort>Description</idShort>
              <valueType>xs:string</valueType>
              <value>Telemetria energética longitudinal (modelo dinâmico) do veículo no CARLA</value>
            </property>

            <submodelElementCollection>
              <idShort>Record</idShort>
              <semanticId>
                <type>ExternalReference</type>
                <keys>
                  <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/Record/1/1</value></key>
                </keys>
              </semanticId>
              <value>
                <property>
                  <idShort>Time</idShort>
                  <semanticId>
                    <type>ExternalReference</type>
                    <keys>
                      <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/UtcTime/1/1</value></key>
                    </keys>
                  </semanticId>
                  <valueType>xs:dateTime</valueType>
                </property>
                <property><idShort>Velocity</idShort><valueType>xs:double</valueType></property>
                <property><idShort>Acceleration</idShort><valueType>xs:double</valueType></property>
                <property><idShort>InstantaneousPower</idShort><valueType>xs:double</valueType></property>
                <property><idShort>AccumulatedEnergy</idShort><valueType>xs:double</valueType></property>
                <property><idShort>DcVoltage</idShort><valueType>xs:double</valueType></property>
                <property><idShort>DcCurrent</idShort><valueType>xs:double</valueType></property>
                <property><idShort>StateOfCharge</idShort><valueType>xs:double</valueType></property>
              </value>
            </submodelElementCollection>
          </value>
        </submodelElementCollection>

        <submodelElementCollection>
          <idShort>Segments</idShort>
          <semanticId>
            <type>ExternalReference</type>
            <keys>
              <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/Segments/1/1</value></key>
            </keys>
          </semanticId>
          <value>
            <submodelElementCollection>
              <idShort>LinkedSegment</idShort>
              <semanticId>
                <type>ExternalReference</type>
                <keys>
                  <key><type>GlobalReference</type><value>https://admin-shell.io/idta/TimeSeries/Segments/LinkedSegment/1/1</value></key>
                </keys>
              </semanticId>
              <value>
                <property>
                  <idShort>Name</idShort>
                  <valueType>xs:string</valueType>
                  <value>TimescaleDB (via API)</value>
                </property>
                <property>
                  <idShort>Endpoint</idShort>
                  <valueType>xs:string</valueType>
                  <value>http://localhost:8000/api/sessions</value>
                </property>
                <property>
                  <idShort>Query</idShort>
                  <valueType>xs:string</valueType>
                  <value>/{sessionId}/telemetry</value>
                </property>
                <property>
                  <idShort>State</idShort>
                  <valueType>xs:string</valueType>
                  <value>in progress</value>
                </property>
              </value>
            </submodelElementCollection>
          </value>
        </submodelElementCollection>

      </submodelElements>
    </submodel>

    <submodel>
      <idShort>EnergyEfficiency</idShort>
