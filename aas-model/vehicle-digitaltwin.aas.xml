          <semanticId>
            <type>ExternalReference</type>
            <keys>
              <key><type>GlobalReference</type><value>https://admin-shell.io/ZVEI/TechnicalData/TechnicalProperties/1/1</value></key>
            </keys>
          </semanticId>
          <value>
            <property><idShort>TotalMass</idShort><valueType>xs:double</valueType><value>110</value></property>
            <property><idShort>DragCoefficient</idShort><valueType>xs:double</valueType><value>0.10</value></property>
            <property><idShort>FrontalArea</idShort><valueType>xs:double</valueType><value>0.5</value></property>
            <property><idShort>RollingResistance</idShort><valueType>xs:double</valueType><value>0.002</value></property>
            <property><idShort>NominalDcVoltage</idShort><valueType>xs:double</valueType><value>48</value></property>
            <property><idShort>BatteryCapacityJ</idShort><valueType>xs:double</valueType><value>5000000</value></property>
          </value>
