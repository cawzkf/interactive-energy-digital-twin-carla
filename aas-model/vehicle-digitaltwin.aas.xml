      <submodels>
        <reference>
          <type>ModelReference</type>
          <keys>
            <key><type>Submodel</type><value>https://marchforce.org/sm/timeseries</value></key>
          </keys>
        </reference>
        <reference>
          <type>ModelReference</type>
          <keys>
            <key><type>Submodel</type><value>https://marchforce.org/sm/energyefficiency</value></key>
          </keys>
        </reference>
        <reference>
          <type>ModelReference</type>
          <keys>
