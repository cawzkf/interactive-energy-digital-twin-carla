
ACQ_SOURCE=carla
NOMINAL_DC_VOLTAGE=48.0

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_RAW=marchforce/telemetry/raw
MQTT_TOPIC_PROCESSED=marchforce/telemetry/processed
MQTT_KEEPALIVE=60

DB_HOST=localhost
DB_PORT=5432
DB_NAME=telemetry
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

API_HOST=0.0.0.0
API_PORT=8000

BASYX_URL=http://localhost:8081

OPCUA_BIND_HOST=0.0.0.0
OPCUA_PORT=4840
OPCUA_PATH=/marchforce/
OPCUA_NAMESPACE=http://marchforce.telemetry
OPCUA_SERVER_NAME=MarchForce Telemetry
OPCUA_OBJECT_NAME=Telemetry
OPCUA_UPDATE_INTERVAL=0.2

LORA_LINK=log
LORA_PORT=/dev/ttyUSB0
LORA_BAUD=9600
LORA_FIELDS=velocity,soc,power,vdc,idc
LORA_MAX_BYTES=200
LORA_MIN_INTERVAL=1.0
